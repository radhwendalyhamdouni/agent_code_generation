      "shape": ["شكل"],
      "layer": ["طبقة"],
      "dense": ["كثيف", "خطي"],
      "conv": ["التفاف", "conv"],
      "pool": ["تجميع", "pool"],
      "dropout": ["إسقاط", "اسقاط"],
      "flatten": ["تسوية", "flatten"],
      "reshape": ["إعادة_تشكيل", "reshape"],
      "activation": ["تنشيط"],
      "softmax": ["سوفت_ماكس", "softmax"],
      "relu": ["ريلو", "relu"],
      "sigmoid": ["سيجمويد", "sigmoid"],
      "batch": ["دفعة", "batch"],
      "train": ["درّب", "درب", "تدريب"],
      "predict": ["توقع", "تنبؤ"],
      "optimizer": ["محسّن", "محقق"],
      "loss": ["خسارة"]
    },
    "ui_layout": {
      "row": ["صف", "صف_أفقي"],
      "column": ["عمود", "صف_عمودي"],
      "grid": ["شبكة_تخطيط", "شبكة_عرض"],
      "flex": ["مرن"],
      "stack": ["كومة"],
      "wrap": ["التفاف"],
      "gap": ["فجوة"],
      "align": ["محاذاة"],
      "justify": ["تبرير"],
      "padding": ["حشو"],
      "margin": ["هامش"]
    },
    "ui_components": {
