  "operators": {
    "arithmetic": {
      "plus": {"symbol": "+", "name": "جمع"},
      "minus": {"symbol": "-", "name": "طرح"},
      "multiply": {"symbol": "*", "name": "ضرب"},
      "divide": {"symbol": "/", "name": "قسمة"},
      "modulo": {"symbol": "%", "name": "باقي"},
      "power": {"symbol": "^", "name": "أس"},
      "floor_div": {"symbol": "//", "name": "قسمة_صحيحة"}
    },
    "comparison": {
      "equal": {"symbol": "==", "name": "يساوي"},
      "not_equal": {"symbol": "!=", "name": "لا_يساوي"},
      "less": {"symbol": "<", "name": "أصغر"},
      "greater": {"symbol": ">", "name": "أكبر"},
      "less_equal": {"symbol": "<=", "name": "أصغر_أو_يساوي"},
      "greater_equal": {"symbol": ">=", "name": "أكبر_أو_يساوي"}
    },
    "assignment": {
      "assign": {"symbol": "=", "name": "إسناد"},
      "plus_assign": {"symbol": "+=", "name": "إسناد_جمع"},
      "minus_assign": {"symbol": "-=", "name": "إسناد_طرح"},
      "mult_assign": {"symbol": "*=", "name": "إسناد_ضرب"},
      "div_assign": {"symbol": "/=", "name": "إسناد_قسمة"},
      "mod_assign": {"symbol": "%=", "name": "إسناد_باقي"},
      "pow_assign": {"symbol": "^=", "name": "إسناد_أس"}
    },
    "logical": {
      "and": {"symbol": "و", "alt": "&&", "name": "و"},
      "or": {"symbol": "أو", "alt": "||", "name": "أو"},
      "not": {"symbol": "ليس", "alt": "!", "name": "ليس"}
    },
    "bitwise": {
      "bit_and": {"symbol": "&", "name": "و_بت"},
      "bit_or": {"symbol": "|", "name": "أو_بت"},
      "bit_xor": {"symbol": "~~", "name": "xor_بت"},
      "bit_not": {"symbol": "~", "name": "نفي_بت"},
      "shift_left": {"symbol": "<<", "name": "إزاحة_يسار"},
      "shift_right": {"symbol": ">>", "name": "إزاحة_يمين"}
    },
    "advanced": {
      "null_coalescing": {"symbol": "؟؟", "alt": "??", "name": "دمج_فارغ"},
      "pipe": {"symbol": "|>", "name": "أنابيب"},
      "optional_chain": {"symbol": "؟.", "alt": "?.", "name": "وصول_آمن"},
      "optional_index": {"symbol": "؟[", "name": "فهرسة_آمنة"},
      "increment": {"symbol": "++", "name": "زيادة"},
      "decrement": {"symbol": "--", "name": "نقصان"}
    }
  },

  "punctuation": {
    "semicolons": ["؛", ";"],
    "commas": ["،", ","],
    "dot": ".",
    "colon": ":",
    "arrow": "->",
    "fat_arrow": "=>",
    "range": "..",
    "spread": "...",
    "question": ["؟", "?"],
    "at": "@"
  },

  "brackets": {
    "parentheses": {"open": "(", "close": ")"},
    "braces": {"open": "{", "close": "}"},
    "brackets": {"open": "[", "close": "]"}
  },

  "regex_patterns": {
    "identifier": {
      "pattern": "[\\p{Arabic}\\p{Latin}_][\\p{Arabic}\\p{Latin}\\p{Nd}_ـ]*",
      "description": "معرف يبدأ بحرف أو شرطة سفلية ويتابع بحروف أو أرقام"
    },
    "arabic_number": {
      "pattern": "[٠-٩]+(\\.[٠-٩]+)?",
      "description": "رقم عربي شرقي"
    },
    "ascii_number": {
      "pattern": "[0-9]+(\\.[0-9]+)?",
      "description": "رقم لاتيني"
    },
    "hex_number": {
      "pattern": "0[xX][0-9a-fA-F]+",
      "description": "رقم سداسي عشر"
    },
    "binary_number": {
      "pattern": "0[bB][01]+",
      "description": "رقم ثنائي"
    },
    "string_double": {
      "pattern": "\"(?:[^\"\\\\]|\\\\.)*\"",
      "description": "نص بين علامتي اقتباس مزدوجة"
    },
    "string_single": {
      "pattern": "'(?:[^'\\\\]|\\\\.)*'",
      "description": "نص بين علامتي اقتباس مفردة"
    },
    "string_multiline": {
      "pattern": "`(?:[^`\\\\]|\\\\.)*`",
      "description": "نص متعدد الأسطر"
    },
    "comment_single": {
      "pattern": "#[^\\n]*",
      "description": "تعليق أحادي السطر"
    },
    "comment_double_slash": {
      "pattern": "//[^\\n]*",
      "description": "تعليق أحادي السطر (نمط C)"
    },
    "comment_multi": {
      "pattern": "/\\*[\\s\\S]*?\\*/",
      "description": "تعليق متعدد الأسطر"
    },
    "whitespace": {
      "pattern": "[\\s\\t\\n\\r]+",
      "description": "مسافات بيضاء"
    }
  },

  "syntax_rules": {
    "variable_declaration": {
      "pattern": "(متغير|م|ثابت|ث)\\s+([\\p{Arabic}\\p{Latin}_][\\p{Arabic}\\p{Latin}\\p{Nd}_ـ]*)\\s*=\\s*(.+)(؛|;)?",
      "example": "متغير الاسم = \"أحمد\"؛",
      "description": "إعلان متغير أو ثابت"
    },
    "function_declaration": {
      "pattern": "دالة\\s+([\\p{Arabic}\\p{Latin}_][\\p{Arabic}\\p{Latin}\\p{Nd}_ـ]*)\\s*\\(([^)]*)\\)\\s*\\{",
      "example": "دالة جمع(أ، ب) { أرجع أ + ب؛ }",
      "description": "تعريف دالة"
    },
    "if_statement": {
      "pattern": "إذا\\s+(.+)\\s*\\{",
      "example": "إذا س > ٥ { اطبع(\"كبير\")؛ }",
      "description": "جملة شرطية"
    },
    "while_loop": {
      "pattern": "طالما\\s+(.+)\\s*\\{",
      "example": "طالما س < ١٠ { س = س + ١؛ }",
      "description": "حلقة طالما"
    },
    "for_loop": {
      "pattern": "لكل\\s+([\\p{Arabic}\\p{Latin}_][\\p{Arabic}\\p{Latin}\\p{Nd}_ـ]*)\\s+في\\s+(.+)\\s*\\{",
      "example": "لكل رقم في [١، ٢، ٣] { اطبع(رقم)؛ }",
      "description": "حلقة لكل"
    },
    "list_literal": {
      "pattern": "\\[(.*)\\]",
      "example": "[١، ٢، ٣، ٤، ٥]",
      "description": "قائمة حرفية"
    },
    "dict_literal": {
      "pattern": "\\{([^\\[\\]]*)\\}",
      "example": "{الاسم: \"أحمد\"، العمر: ٢٥}",
      "description": "قاموس حرفي"
    },
    "lambda_expression": {
      "pattern": "\\(([^)]*)\\)\\s*=>\\s*(.+)",
      "example": "(ن) => ن ^ ٢",
      "description": "تعبير لامدا"
    },
    "list_comprehension": {
      "pattern": "\\[(.+)\\s+لكل\\s+([\\p{Arabic}\\p{Latin}_][\\p{Arabic}\\p{Latin}\\p{Nd}_ـ]*)\\s+في\\s+(.+?)(\\s+إذا\\s+(.+))?\\]",
      "example": "[ن * ٢ لكل ن في أرقام]",
      "description": "قائمة استيعابية"
    },
    "enum_declaration": {
      "pattern": "تعداد\\s+([\\p{Arabic}\\p{Latin}_][\\p{Arabic}\\p{Latin}\\p{Nd}_ـ]*)\\s*\\{",
      "example": "تعداد لون { أحمر، أخضر، أزرق }",
      "description": "تعريف تعداد"
    },
    "data_class_declaration": {
      "pattern": "بيانات\\s+([\\p{Arabic}\\p{Latin}_][\\p{Arabic}\\p{Latin}\\p{Nd}_ـ]*)\\s*\\{",
      "example": "بيانات منتج { اسم: نص، سعر: رقم }",
      "description": "تعريف فئة بيانات"
    },
    "class_declaration": {
      "pattern": "صنف\\s+([\\p{Arabic}\\p{Latin}_][\\p{Arabic}\\p{Latin}\\p{Nd}_ـ]*)(\\s*:\\s*([\\p{Arabic}\\p{Latin}_][\\p{Arabic}\\p{Latin}\\p{Nd}_ـ]*))?\\s*\\{",
      "example": "صنف شخص { متغير الاسم؛ دالة تعريف() { } }",
      "description": "تعريف صنف"
    },
    "try_catch": {
      "pattern": "حاول\\s*\\{(.*)\\}\\s*امسك\\s*(?:\\(([^)]+)\\))?\\s*\\{(.*)\\}(\\s*أخيراً\\s*\\{(.*)\\})?",
      "example": "حاول { } امسك (خطأ) { }",
      "description": "معالجة الأخطاء"
    },
    "decorator": {
      "pattern": "@([\\p{Arabic}\\p{Latin}_][\\p{Arabic}\\p{Latin}\\p{Nd}_ـ]*)",
      "example": "@قياس_الوقت",
      "description": "زخرفة"
    },
    "with_statement": {
      "pattern": "مع\\s+(.+?)(\\s+كـ\\s+([\\p{Arabic}\\p{Latin}_][\\p{Arabic}\\p{Latin}\\p{Nd}_ـ]*))?\\s*\\{",
      "example": "مع ملف كـ و { اطبع(و.اقرأ())؛ }",
      "description": "مدير سياق"
    }
  },

  "type_annotations": {
    "simple_types": ["رقم", "عدد", "نص", "منطقي", "قائمة", "قاموس", "لا_شيء"],
    "generic_syntax": {
      "list": "[نوع]",
      "dict": "{مفتاح: قيمة}",
      "optional": "نوع؟",
      "function": "(معاملات) -> نتيجة",
      "union": "نوع أ | نوع ب"
    },
    "examples": [
      "متغير العمر: رقم = ٢٥؛",
      "دالة جمع(أ: رقم، ب: رقم) -> رقم { أرجع أ + ب؛ }",
      "متجر أسماء: [نص] = [\"أحمد\"، \"محمد\"]؛"
    ]
  },

