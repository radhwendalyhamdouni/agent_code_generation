      "مجموع": {"params": ["أرقام"], "description": "مجموع العناصر"},
      "متوسط": {"params": ["أرقام"], "description": "المتوسط"},
      "أدنى": {"params": ["أرقام"], "description": "أصغر قيمة"},
      "أقصى": {"params": ["أرقام"], "description": "أكبر قيمة"},
      "رتب": {"params": ["قائمة"], "description": "ترتيب القائمة"},
      "اعكس": {"params": ["قائمة"], "description": "عكس القائمة"},
      "فريد": {"params": ["قائمة"], "description": "إزالة المكررات"},
      "أضف": {"params": ["قائمة", "عنصر"], "description": "إضافة عنصر"},
      "أزل": {"params": ["قائمة", "فهرس"], "description": "إزالة عنصر"},
      "ابحث": {"params": ["قائمة", "عنصر"], "description": "البحث عن عنصر"}
    },
    "string_operations": {
      "كبير": {"params": ["نص"], "description": "تحويل لحروف كبيرة"},
      "صغير": {"params": ["نص"], "description": "تحويل لحروف صغيرة"},
      "اقتطع": {"params": ["نص", "بداية", "نهاية"], "description": "اقتطاع جزء"},
      "انقسم": {"params": ["نص", "فاصل"], "description": "تقسيم النص"},
      "اجمع": {"params": ["قائمة", "فاصل"], "description": "دمج النصوص"},
      "استبدل": {"params": ["نص", "قديم", "جديد"], "description": "استبدال"},
      "يبدأ_ب": {"params": ["نص", "بداية"], "description": "التحقق من البداية"},
      "ينتهي_ب": {"params": ["نص", "نهاية"], "description": "التحقق من النهاية"}
    },
    "dict_operations": {
      "مفاتيح": {"params": ["قاموس"], "description": "الحصول على المفاتيح"},
      "قيم": {"params": ["قاموس"], "description": "الحصول على القيم"}
    },
    "utility": {
      "نوع": {"params": ["قيمة"], "description": "نوع القيمة"},
      "نطاق": {"params": ["بداية", "نهاية", "خطوة?"], "description": "إنشاء نطاق"}
    }
  },

  "error_messages": {
    "arabic": {
      "undefined_variable": "المتغير '{name}' غير معرف",
      "cannot_modify_const": "لا يمكن تعديل الثابت '{name}'",
      "type_error": "خطأ في النوع: {expected} متوقع، وجد {found}",
      "division_by_zero": "خطأ: القسمة على صفر",
      "index_out_of_bounds": "الفهرس {index} خارج النطاق",
      "function_not_found": "الدالة '{name}' غير موجودة",
      "wrong_arguments": "عدد المعاملات غير صحيح",
      "syntax_error": "خطأ نحوي في السطر {line}: {message}",
      "unclosed_string": "نص غير مغلق في السطر {line}",
      "unclosed_bracket": "قوس غير مغلق"
    }
  },

  "code_style": {
    "indentation": {
      "style": "spaces",
      "size": 4
    },
    "naming_conventions": {
      "variables": "snake_case أو camelCase بالعربية",
      "functions": "snake_case بالعربية",
      "classes": "PascalCase بالعربية",
      "constants": "UPPER_SNAKE_CASE"
    },
    "semicolons": "اختيارية (؛ أو ;)",
    "max_line_length": 100
  }
}
