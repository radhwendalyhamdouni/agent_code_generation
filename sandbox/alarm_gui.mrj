// ═══════════════════════════════════════════════════════════════
//            ⏰ تطبيق المنبه الذكي - واجهة Flutter
//                  Alarm App with Flutter GUI
// ═══════════════════════════════════════════════════════════════

// البيانات
متغير قائمة_المنبهات = []؛
متغير معرف_التالي = 1؛

// تنسيق الوقت
دالة تنسيق_الوقت(ساعة، دقيقة) {
    متغير س = ساعة؛
    متغير د = دقيقة؛
    إذا ساعة < 10 {
        س = "0" + ساعة؛
    }
    إذا دقيقة < 10 {
        د = "0" + دقيقة؛
    }
    أرجع س + ":" + د؛
}

// التحقق من صحة الوقت
دالة وقت_صحيح(ساعة، دقيقة) {
    إذا ساعة < 0 أو ساعة > 23 {
        أرجع false؛
    }
    إذا دقيقة < 0 أو دقيقة > 59 {
        أرجع false؛
    }
    أرجع true؛
}

// إضافة منبه جديد
دالة إضافة_منبه(ساعة، دقيقة، عنوان) {
    إذا !وقت_صحيح(ساعة، دقيقة) {
        أرجع -1؛
    }
    
    متغير منبه_جديد = {}؛
    منبه_جديد["معرف"] = معرف_التالي؛
    منبه_جديد["ساعة"] = ساعة؛
    منبه_جديد["دقيقة"] = دقيقة؛
    منبه_جديد["عنوان"] = عنوان؛
    منبه_جديد["نشط"] = true؛
    منبه_جديد["غفوات"] = 0؛
    
    قائمة_المنبهات = قائمة_المنبهات + [منبه_جديد]؛
    معرف_التالي = معرف_التالي + 1؛
    
    أرجع معرف_التالي - 1؛
}

// حذف منبه
دالة حذف_منبه(المعرف) {
    متغير قائمة_جديدة = []؛
    
    لكل منبه في قائمة_المنبهات {
        إذا منبه["معرف"] != المعرف {
            قائمة_جديدة = قائمة_جديدة + [منبه]؛
        }
    }
    
    قائمة_المنبهات = قائمة_جديدة؛
    أرجع true؛
}

// تبديل حالة المنبه
دالة تبديل_منبه(المعرف) {
    لكل منبه في قائمة_المنبهات {
        إذا منبه["معرف"] == المعرف {
            منبه["نشط"] = !منبه["نشط"]؛
            أرجع منبه["نشط"]؛
        }
    }
    أرجع false؛
}

// غفوة
دالة غفوة(المعرف) {
    لكل منبه في قائمة_المنبهات {
        إذا منبه["معرف"] == المعرف {
            متغير دقائق_جديدة = منبه["دقيقة"] + 5؛
            متغير ساعات_إضافية = 0؛
            
            إذا دقائق_جديدة >= 60 {
                دقائق_جديدة = دقائق_جديدة - 60؛
                ساعات_إضافية = 1؛
            }
            
            منبه["دقيقة"] = دقائق_جديدة؛
            منبه["ساعة"] = منبه["ساعة"] + ساعات_إضافية؛
            
            إذا منبه["ساعة"] >= 24 {
                منبه["ساعة"] = منبه["ساعة"] - 24؛
            }
            
            منبه["غفوات"] = منبه["غفوات"] + 1؛
            أرجع true؛
        }
    }
    أرجع false؛
}

// عدد المنبهات النشطة
دالة عدد_المنبهات_النشطة() {
    متغير عدد = 0؛
    لكل منبه في قائمة_المنبهات {
        إذا منبه["نشط"] {
            عدد = عدد + 1؛
        }
    }
    أرجع عدد؛
}

// ═══════════════════════════════════════════════════════════════
// تشغيل التطبيق
// ═══════════════════════════════════════════════════════════════

// إضافة منبهات افتراضية
إضافة_منبه(6، 30، "الاستيقاظ للعمل")؛
إضافة_منبه(7، 15، "الرياضة الصباحية")؛
إضافة_منبه(5، 45، "صلاة الفجر")؛

// عرض المعلومات
اطبع("╔══════════════════════════════════════════════════════════╗")؛
اطبع("║        ⏰  تـطـبـيـق الـمـنـبـه الـذهـي  ⏰              ║")؛
اطبع("╠══════════════════════════════════════════════════════════╣")؛
اطبع("║  المنبهات النشطة: " + عدد_المنبهات_النشطة() + "                              ║")؛
اطبع("╠══════════════════════════════════════════════════════════╣")؛

لكل منبه في قائمة_المنبهات {
    متغير رمز = "🔴"؛
    إذا منبه["نشط"] {
        رمز = "🟢"؛
    }
    اطبع("║  " + رمز + " " + تنسيق_الوقت(منبه["ساعة"]، منبه["دقيقة"]) + " - " + منبه["عنوان"])؛
}

اطبع("╚══════════════════════════════════════════════════════════╝")؛

اطبع("")؛
اطبع("📱 هذا التطبيق يمكن تصديره إلى:")؛
