// ═══════════════════════════════════════════════════════════════
//                    ⏰ تطبيق المنبه الذكي
//                   Alarm Application v2.0
// ═══════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────────
// المتغيرات العامة - Global Variables
// ─────────────────────────────────────────────────────────────────
متغير قائمة_المنبهات = []؛
متغير معرف_التالي = 1؛

// ─────────────────────────────────────────────────────────────────
// دوال المساعدة - Helper Functions
// ─────────────────────────────────────────────────────────────────

// تنسيق الوقت بصيغة HH:MM
دالة تنسيق_الوقت(ساعة، دقيقة) {
    متغير س = ساعة؛
    متغير د = دقيقة؛
    إذا ساعة < 10 {
        س = "0" + ساعة؛
    }
    إذا دقيقة < 10 {
        د = "0" + دقيقة؛
    }
    أرجع س + ":" + د؛
}

// التحقق من صحة الوقت
دالة وقت_صحيح(ساعة، دقيقة) {
    إذا ساعة < 0 أو ساعة > 23 {
        أرجع false؛
    }
    إذا دقيقة < 0 أو دقيقة > 59 {
        أرجع false؛
    }
    أرجع true؛
}

// ─────────────────────────────────────────────────────────────────
// دوال إدارة المنبهات - Alarm Management Functions
// ─────────────────────────────────────────────────────────────────

// إضافة منبه جديد
دالة إضافة_منبه(ساعة، دقيقة، عنوان) {
    إذا !وقت_صحيح(ساعة، دقيقة) {
        اطبع("❌ خطأ: وقت غير صالح!")؛
        أرجع -1؛
    }
    
    متغير منبه_جديد = {}؛
    منبه_جديد["معرف"] = معرف_التالي؛
    منبه_جديد["ساعة"] = ساعة؛
    منبه_جديد["دقيقة"] = دقيقة؛
    منبه_جديد["عنوان"] = عنوان؛
    منبه_جديد["نشط"] = true؛
    منبه_جديد["غفوات"] = 0؛
    
    قائمة_المنبهات = قائمة_المنبهات + [منبه_جديد]؛
    معرف_التالي = معرف_التالي + 1؛
    
    اطبع("✅ تم إضافة المنبه: " + عنوان)؛
    اطبع("   الوقت: " + تنسيق_الوقت(ساعة، دقيقة))؛
    أرجع معرف_التالي - 1؛
}

// حذف منبه
دالة حذف_منبه(المعرف) {
    متغير قائمة_جديدة = []؛
    متغير موجود = false؛
    
    لكل منبه في قائمة_المنبهات {
        إذا منبه["معرف"] != المعرف {
            قائمة_جديدة = قائمة_جديدة + [منبه]؛
        } وإلا {
            موجود = true؛
        }
    }
    
    قائمة_المنبهات = قائمة_جديدة؛
    
    إذا موجود {
        اطبع("🗑️ تم حذف المنبه رقم " + المعرف)؛
        أرجع true؛
    }
    اطبع("⚠️ لم يتم العثور على المنبه")؛
    أرجع false؛
}

// تفعيل/تعطيل منبه
دالة تبديل_منبه(المعرف) {
    لكل منبه في قائمة_المنبهات {
        إذا منبه["معرف"] == المعرف {
            منبه["نشط"] = !منبه["نشط"]؛
            إذا منبه["نشط"] {
                اطبع("🔔 تم تفعيل المنبه: " + منبه["عنوان"])؛
            } وإلا {
                اطبع("🔕 تم تعطيل المنبه: " + منبه["عنوان"])؛
            }
            أرجع true؛
        }
    }
    أرجع false؛
}

// غفوة - تأخير المنبه 5 دقائق
دالة غفوة(المعرف) {
    لكل منبه في قائمة_المنبهات {
        إذا منبه["معرف"] == المعرف {
            متغير دقائق_جديدة = منبه["دقيقة"] + 5؛
            متغير ساعات_إضافية = 0؛
            
            إذا دقائق_جديدة >= 60 {
                دقائق_جديدة = دقائق_جديدة - 60؛
                ساعات_إضافية = 1؛
            }
            
            منبه["دقيقة"] = دقائق_جديدة؛
            منبه["ساعة"] = منبه["ساعة"] + ساعات_إضافية؛
            
            إذا منبه["ساعة"] >= 24 {
                منبه["ساعة"] = منبه["ساعة"] - 24؛
            }
            
            منبه["غفوات"] = منبه["غفوات"] + 1؛
            
            اطبع("💤 غفوة 5 دقائق...")؛
            اطبع("   الوقت الجديد: " + تنسيق_الوقت(منبه["ساعة"]، منبه["دقيقة"]))؛
            أرجع true؛
        }
    }
    أرجع false؛
}

// ─────────────────────────────────────────────────────────────────
// دوال العرض - Display Functions
// ─────────────────────────────────────────────────────────────────

// عرض كل المنبهات
دالة عرض_المنبهات() {
    اطبع("")؛
    اطبع("╔════════════════════════════════════════════════╗")؛
    اطبع("║              ⏰ قائمة المنبهات                  ║")؛
    اطبع("╠════════════════════════════════════════════════╣")؛
    
    إذا طول(قائمة_المنبهات) == 0 {
        اطبع("║         لا توجد منبهات مضافة حالياً            ║")؛
    } وإلا {
        لكل منبه في قائمة_المنبهات {
            متغير رمز = "🔴"؛
            إذا منبه["نشط"] {
                رمز = "🟢"؛
            }
            
            اطبع("║ " + رمز + " #" + منبه["معرف"] + " | " + تنسيق_الوقت(منبه["ساعة"]، منبه["دقيقة"]) + " | " + منبه["عنوان"])؛
            
            إذا منبه["غفوات"] > 0 {
                اطبع("║    └─ عدد الغفوات: " + منبه["غفوات"])؛
            }
        }
    }
    
    اطبع("╚════════════════════════════════════════════════╝")؛
    اطبع("")؛
}

// عرض واجهة التطبيق
دالة عرض_الواجهة() {
    اطبع("")؛
    اطبع("╔══════════════════════════════════════════════════════════╗")؛
    اطبع("║                                                          ║")؛
    اطبع("║        ⏰  تـطـبـيـق الـمـنـبـه الـذهـي  ⏰              ║")؛
    اطبع("║                                                          ║")؛
    اطبع("║        ────────────────────────────────                  ║")؛
    اطبع("║                                                          ║")؛
    اطبع("║    [1] ➕ إضافة منبه جديد                               ║")؛
    اطبع("║    [2] 📋 عرض جميع المنبهات                             ║")؛
    اطبع("║    [3] 🔄 تفعيل/تعطيل منبه                              ║")؛
    اطبع("║    [4] 💤 غفوة (تأخير 5 دقائق)                          ║")؛
    اطبع("║    [5] 🗑️ حذف منبه                                      ║")؛
    اطبع("║    [0] 🚪 خروج                                          ║")؛
    اطبع("║                                                          ║")؛
    اطبع("╚══════════════════════════════════════════════════════════╝")؛
    اطبع("")؛
}

// عرض معلومات التطبيق
دالة عرض_حول() {
    اطبع("")؛
    اطبع("╔════════════════════════════════════════════════╗")؛
    اطبع("║              ℹ️ حول التطبيق                    ║")؛
    اطبع("╠════════════════════════════════════════════════╣")؛
    اطبع("║  تطبيق المنبه الذكي                            ║")؛
    اطبع("║  الإصدار: 2.0                                  ║")؛
    اطبع("║  اللغة: المرجع (Al-Marjaa)                     ║")؛
    اطبع("║                                                ║")؛
    اطبع("║  الميزات:                                      ║")؛
    اطبع("║  • إدارة منبهات متعددة                         ║")؛
    اطبع("║  • تفعيل/تعطيل المنبهات                        ║")؛
    اطبع("║  • غفوة ذكية (5 دقائق)                         ║")؛
    اطبع("║  • تتبع عدد الغفوات                            ║")؛
    اطبع("╚════════════════════════════════════════════════╝")؛
    اطبع("")؛
}

// ─────────────────────────────────────────────────────────────────
// تشغيل التطبيق - Run Application
// ─────────────────────────────────────────────────────────────────

// عرض الواجهة الرئيسية
عرض_الواجهة()؛

// إضافة منبهات تجريبية
اطبع("📝 إضافة منبهات تجريبية...")؛
اطبع("")؛

إضافة_منبه(6، 30، "الاستيقاظ للعمل")؛
إضافة_منبه(7، 0، "الرياضة الصباحية")؛
إضافة_منبه(5، 45، "صلاة الفجر")؛
إضافة_منبه(9، 0، "اجتماع الفريق")؛

// عرض المنبهات
عرض_المنبهات()؛

// اختبار غفوة
اطبع("🧪 اختبار ميزة الغفوة...")؛
غفوة(1)؛
اطبع("")؛

// اختبار التبديل
اطبع("🧪 اختبار التبديل...")؛
تبديل_منبه(2)؛
اطبع("")؛

// عرض المنبهات بعد التعديلات
عرض_المنبهات()؛

// عرض معلومات التطبيق
عرض_حول()؛

// رسالة النهاية
اطبع("✅ تم تشغيل التطبيق بنجاح!")؛
