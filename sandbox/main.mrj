// متغيرات الموقع
متغير عنوان_الموقع = "شركة أكواب ورقية - الجودة في كل رشة";
متغير وصف_الموقع = "نقدم أفضل أنواع الأكواب الورقية بأحدث التصاميم وأعلى الجودة";
متغير لون_الأولي = "#4CAF50";

// دالة لعرض رأس الصفحة
دالة عرض_رأس_الصفحة() {
    اطبع("<!DOCTYPE html>");
    اطبع("<html lang='ar'>");
    اطبع("<head>");
    اطبع("    <meta charset='UTF-8'>");
    اطبع("    <meta name='viewport' content='width=device-width, initial-scale=1.0'>");
    اطبع("    <title>" + عنوان_الموقع + "</title>");
    اطبع("    <style>");
    اطبع("        body { font-family: 'Arial', sans-serif; line-height: 1.6; margin: 0; padding: 0; background-color: #f4f4f4; }");
    اطبع("        .header { background-color: " + لون_الأولي + "; color: white; padding: 20px 0; text-align: center; }");
    اطبع("        .container { max-width: 1200px; margin: auto; padding: 20px; }");
    اطبع("        .product { background: white; padding: 20px; margin: 20px 0; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }");
    اطبع("        .footer { background-color: #333; color: white; text-align: center; padding: 20px 0; margin-top: 20px; }");
    اطبع("        h1, h2 { color: " + لون_الأولي + "; }");
    اطبع("    </style>");
    اطبع("</head>");
    اطبع("<body>");
    اطبع("    <div class='header'>");
    اطبع("        <h1>" + عنوان_الموقع + "</h1>");
    اطبع("        <p>" + وصف_الموقع + "</p>");
    اطبع("    </div>");
    اطبع("    <div class='container'>");
}

// دالة لعرض المنتجات
دالة عرض_المنتجات() {
    اطبع("        <h2>منتجاتنا</h2>");
    اطبع("        <div class='products'>");
    
    متغير منتجات = [
        { اسم: "كوب قهوة صغير", وصف: "مثالي للقهوة السريعة", حجم: "أونتين", سعر: "0.50 ريال" },
        { اسم: "كوب قهوة متوسط", وصف: "حجم مثالي للمقاهي", حجم: "16 أونس", سعر: "0.75 ريال" },
        { اسم: "كوب ماء كبير", وصف: "مصمم لتقديم كميات كبيرة", حجم: "24 أونس", سعر: "1.00 ريال" },
        { اسم: "كوب آيس كريم", وصف: "تصميم جذاب للأطفال", حجم: "8 أونس", سعر: "0.60 ريال" }
    ];
    
    لكل منتج في منتجات {
        اطبع("            <div class='product'>");
        اطبع("                <h3>" + منتج.اسم + "</h3>");
        اطبع("                <p>" + منتج.وصف + "</p>");
        اطبع("                <p><strong>الحجم:</strong> " + منتج.حجم + "</p>");
        اطبع("                <p><strong>السعر:</strong> " + منتج.سعر + " للوحدة</p>");
        اطبع("            </div>");
    }
    
    اطبع("        </div>");
}

// دالة لعرض معلومات التواصل
دالة عرض_معلومات_التواصل() {
    اطبع("        <h2>تواصل معنا</h2>");
    اطبع("        <div class='contact-info'>");
    اطبع("            <p><strong>العنوان:</strong> الرياض، المملكة العربية السعودية</p>");
    اطبع("            <p><strong>الهاتف:</strong> 920000000</p>");
    اطبع("            <p><strong>البريد الإلكتروني:</strong> info@acwa.com</p>");
    اطبع("            <p><strong>ساعات العمل:</strong> الأحد - الخميس 8 ص - 5 م</p>");
    اطبع("        </div>");
}

// دالة لعرض تذييل الصفحة
دالة عرض_تذييل_الصفحة() {
    اطبع("    </div>");
    اطبع("    <div class='footer'>");
    اطبع("        <p>&copy; " + وقت() + " شركة أكواب ورقية. جميع الحقوق محفوظة.</p>");
    اطبع("    </div>");
    اطبع("</body>");
    اطبع("</html>");
}

// تشغيل الموقع
عرض_رأس_الصفحة()؛
عرض_المنتجات()؛
عرض_معلومات_التواصل()؛
عرض_تذييل_الصفحة()؛