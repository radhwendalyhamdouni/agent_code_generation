دالة ترتيب_قائمة(قائمة) {
    دالة مقارنة(أ، ب) {
        أرجع أ - ب؛
    }
    
    دالة فرز(قائمة) {
        متغير n = طول(قائمة)؛
        
        لكل i في [0، n - 1] {
            متغير أصغر = i؛
            
            لكل j في [i + 1، n] {
                إذا قائمة[j] < قائمة[أصغر] {
                    أصغر = j؛
                }
            }
            
            // تبديل العناصر
            متغير مؤقت = قائمة[i]؛
            قائمة[i] = قائمة[أصغر]؛
            قائمة[أصغر] = مؤقت؛
        }
        
        أرجع قائمة؛
    }
    
    أرجع فرز(قائمة)؛
}

// مثال للاستخدام
متغير قائمة_أرقام = [5, 2, 8, 1, 9, 3]؛
اطبع("القائمة الأصلية: " + قائمة_أرقام)؛

متغير قائمة_مرتبة = ترتيب_قائمة(قائمة_أرقام)؛
اطبع("القائمة المرتبة: " + قائمة_مرتبة)؛

// مثال مع نصوص
متغير قائمة_أسماء = ["زيد", "ياسر", "أحمد", "سامي"]؛
اطبع("\nالقائمة الأصلية: " + قائمة_أسماء)؛

متغير قائمة_أسماء_مرتبة = ترتيب_قائمة(قائمة_أسماء)؛
اطبع("القائمة المرتبة: " + قائمة_أسماء_مرتبة)؛