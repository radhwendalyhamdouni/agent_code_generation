دالة جمع(أ، ب) {
    أرجع أ + ب؛
}

دالة طرح(أ، ب) {
    أرجع أ - ب؛
}

دالة ضرب(أ، ب) {
    أرجع أ * ب؛
}

دالة قسمة(أ، ب) {
    أرجع أ / ب؛
}

دالة حاسبة() {
    اطبع("مرحباً بك في الحاسبة البسيطة")؛
    اطبع("1. جمع")؛
    اطبع("2. طرح")؛
    اطبع("3. ضرب")؛
    اطبع("4. قسمة")؛
    اطبع("5. خروج")؛
    
    متغير اختيار = 1؛
    طالما اختيار != 5 {
        اطبع("اختر عملية (1-5): ")؛
        // في تطبيق حقيقي، سنقرأ المدخلات هنا
        
        إذا اختيار == 1 {
            متغير نتيجة = جمع(10، 5)؛
            اطبع("10 + 5 = " + نتيجة)؛
        } وإذا اختيار == 2 {
            متغير نتيجة = طرح(10، 5)؛
            اطبع("10 - 5 = " + نتيجة)؛
        } وإذا اختيار == 3 {
            متغير نتيجة = ضرب(10، 5)؛
            اطبع("10 * 5 = " + نتيجة)؛
        } وإذا اختيار == 4 {
            متغير نتيجة = قسمة(10، 5)؛
            اطبع("10 / 5 = " + نتيجة)؛
        } وإذا اختيار == 5 {
            اطبع("وداعاً!")؛
        } وإلا {
            اطبع("اخيار غير صالح، حاول مرة أخرى")؛
        }
    }
}

حاسبة()؛